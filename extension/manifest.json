{
  "manifest_version": 3,
  "name": "2FA Guard",
  "version": "1.0.0",
  "description": "本地 TOTP 两步验证码生成工具，密钥不会发送到外部服务。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "extension/popup.html",
    "default_title": "2FA Guard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": ["clipboardRead", "clipboardWrite"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
