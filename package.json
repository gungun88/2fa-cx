{
  "name": "2fa-guard",
  "version": "1.0.0",
  "description": "2FA Guard web and browser extension for local TOTP codes, QR import, and JSON backup.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/index.mjs",
    "build": "tsc && vite build",
    "build:extension": "tsc && vite build --config vite.extension.config.ts",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.4.2"
  }
}
