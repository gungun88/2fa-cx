{
  "name": "2fa-guard",
  "version": "1.0.0",
  "description": "2FA Guard web tools.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/index.mjs",
    "dev:all": "concurrently -n web,api -c cyan,magenta \"npm:dev\" \"npm:dev:api\"",
    "build": "tsc && vite build",
    "build:extension": "vite build --config extension/vite.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src --ext ts,tsx"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "jsqr": "^1.4.0",
    "playwright-core": "^1.59.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "daisyui": "^4.12.24",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  }
}
